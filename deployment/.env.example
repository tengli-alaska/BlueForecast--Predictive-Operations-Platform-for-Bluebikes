# BlueForecast Deployment — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── GCP Configuration ─────────────────────────────────────────────────────────
PROJECT_ID=your-gcp-project-id
REGION=us-east1

# ── Artifact Registry ─────────────────────────────────────────────────────────
REGISTRY=us-east1-docker.pkg.dev
REPO=blueforecast
IMAGE_TAG=latest

# ── Cloud Run Service Names ────────────────────────────────────────────────────
API_SERVICE=blueforecast-api
DASHBOARD_SERVICE=blueforecast-dashboard

# ── GCS ───────────────────────────────────────────────────────────────────────
GCS_BUCKET=bluebikes-demand-predictor-data

# ── Model Serving ─────────────────────────────────────────────────────────────
# Set after first deploy — used by refresh_serving.sh
API_URL=https://blueforecast-api-xxxx-ue.a.run.app
DASHBOARD_URL=https://blueforecast-dashboard-xxxx-ue.a.run.app
REFRESH_TOKEN=20240101T000000Z

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
# Optional email notifications
NOTIFY_EMAIL=team@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sender@example.com
SMTP_PASS=your-app-password

# ── Model Pipeline ────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=mlruns
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Retraining Flags ──────────────────────────────────────────────────────────
# Set to true to enable quick 5% sample run (CI speed)
QUICK_CHECK=false
# Set to true to enable Optuna Bayesian HPO
RUN_OPTUNA=false
# Set to true to skip OAT hyperparameter sweep
SKIP_SWEEP=true
# Set to true to bypass promotion gates (emergency only)
FORCE_PROMOTE=false
# Required when FORCE_PROMOTE=true
BIAS_OVERRIDE_REASON=
